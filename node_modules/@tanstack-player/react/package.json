{
  "name": "@tanstack-player/react",
  "version": "2.0.3",
  "description": "TanStack Player — React component and hooks",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "sideEffects": false,
  "license": "MIT",
  "dependencies": {
    "@tanstack-player/core": "*",
    "@tanstack-player/adapter-videojs": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "video.js": ">=7.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "video.js": "^8.0.0"
  }
}
